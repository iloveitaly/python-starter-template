  "components": {
    "schemas": {
      "AppData": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message",
            "default": "Hello From Internal Python"
          },
          "user_id": {
            "type": "string",
            "title": "User Id"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "user_id"
        ],
        "title": "AppData"
      },
      "ErrorDetail": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "param": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Param"
          },
          "details": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Details"
          }
        },
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "ErrorDetail",
        "description": "Standard error payload returned to clients.\n\nShape loosely follows Stripe: machine-readable `code`, human-readable\n`message`, optional `param` pointing at the offending field, and an\noptional `details` bag for structured context."
      },
      "ErrorResponse": {
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        },
        "type": "object",
        "required": [
          "error"
        ],
        "title": "ErrorResponse",
        "description": "Envelope wrapping `ErrorDetail` under an `error` key.\n\nThe wrapper gives error responses a stable shape (`{\"error\": {...}}`)\nthat clients can discriminate on, and leaves room to add sibling\ntop-level fields later (e.g., `request_id`, `meta`) without a\nbreaking change."
      },
      "UserListResponse": {
        "properties": {
          "current_user": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/UserSwitchData"
              },
              {
                "type": "null"
              }
            ]
          },
          "users": {
            "items": {
              "$ref": "#/components/schemas/UserSwitchData"
            },
            "type": "array",
            "title": "Users"
          }
        },
        "type": "object",
        "required": [
          "current_user",
          "users"
        ],
        "title": "UserListResponse"
      },
      "UserSwitchData": {
        "properties": {
          "clerk_id": {
            "type": "string",
            "title": "Clerk Id"
          },
          "id": {
            "type": "string",
            "format": "typeid",
            "title": "Id"
          },
          "email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Email"
          }
        },
        "type": "object",
        "required": [
          "clerk_id",
          "id",
          "email"
        ],
        "title": "UserSwitchData"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      },
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "token"
          }
        }
      }
    }
  }
